---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found">
  <section class="wrap" style="padding: 90px 0; text-align: center;">
    <p class="eyebrow" style="justify-content:center;">Error 404</p>
    <h1 style="font-size: clamp(40px, 9vw, 88px); margin-top: 10px;">¯\_(ツ)_/¯</h1>
    <p class="lead" style="max-width: 420px; margin: 18px auto 0;">
      That page doesn't exist. The symbol you want is probably on the character map.
    </p>
    <p style="margin-top: 26px;">
      <a class="pill is-active" href="/symbols/">Browse all symbols</a>
    </p>
  </section>
</Base>
