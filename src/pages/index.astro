---
import Base from '../layouts/Base.astro';
import Glyph from '../components/Glyph.astro';
import { POPULAR, CATEGORIES, SYMBOLS } from '../data/symbols.js';
import { getCollection } from 'astro:content';
import { SITE } from '../consts.js';

const guides = (await getCollection('guides')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const counts = Object.fromEntries(
  CATEGORIES.map((c) => [c, SYMBOLS.filter((s) => s.category === c).length])
);
---

<Base>
  <section class="wrap hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Unicode, instantly</p>
        <h1 style="font-size: clamp(36px, 6.4vw, 62px); max-width: 620px; margin-top: 16px;">
          Inspect, copy, and learn any symbol.
        </h1>
        <p class="lead" style="max-width: 520px; margin-top: 18px;">
          A fast character inspector for {SYMBOLS.length}+ symbols — arrows, accents, currency,
          math and more. Hover to inspect, tap to copy.
        </p>
        <div class="stat-row">
          <span class="stat"><b>{SYMBOLS.length}</b> characters</span>
          <span class="stat"><b>{CATEGORIES.length}</b> categories</span>
          <span class="stat"><b>{guides.length}</b> how-to guides</span>
        </div>
      </div>
      <div class="feature" data-feature aria-hidden="true">
        <span class="fch">→</span>
      </div>
    </div>

    <div style="max-width: 560px; margin-top: 34px;">
      <label class="search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="color: var(--muted-2); flex: none;">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
          <path d="M20 20l-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <input type="search" placeholder="Search symbols…  (try “euro”, “arrow”, “é”)" data-search autocomplete="off" aria-label="Search symbols" />
        <span class="kbd-hint">/</span>
      </label>
    </div>

    <div class="cat-bar" style="margin-top: 18px;">
      <button class="pill is-active" type="button" data-cat-pill="All">All</button>
      {CATEGORIES.map((cat) => (
        <button class="pill" type="button" data-cat-pill={cat}>
          {cat}<span class="count">{counts[cat]}</span>
        </button>
      ))}
    </div>

    <div class="recent" data-recent>
      <div class="label">Recently copied</div>
      <div class="row" data-recent-row></div>
    </div>

    <div class="glyph-grid" data-grid style="margin-top: 22px;">
      {SYMBOLS.map((sym) => <Glyph sym={sym} />)}
    </div>
    <p class="empty" data-empty style="display:none;">
      No symbols match that search. Try a simpler word.
    </p>
  </section>

  <section class="wrap section">
    <div class="section-head">
      <h2>Most-copied</h2>
      <a href="/symbols/">Browse all →</a>
    </div>
    <div class="glyph-grid">
      {POPULAR.map((sym) => <Glyph sym={sym} />)}
    </div>
  </section>

  {guides.length > 0 && (
    <section class="wrap section">
      <div class="section-head">
        <h2>How-to guides</h2>
        <a href="/guides/">All guides →</a>
      </div>
      <div class="guide-list">
        {guides.slice(0, 6).map((g) => (
          <a class="guide-card" href={`/guides/${g.id}/`}>
            <span class="gch">{g.data.symbol}</span>
            <span>
              <span class="gtitle">{g.data.title}</span>
              <span class="gsub">{g.data.shortName}</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  )}
</Base>
