---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const shortcuts = [
  d.winShortcut && { label: 'Windows', value: d.winShortcut },
  d.macShortcut && { label: 'Mac', value: d.macShortcut },
].filter(Boolean);
---

<Base title={d.title} description={d.description} ogType="article">
  <article class="wrap article" style="padding-top: 48px;">
    <p class="eyebrow"><a href="/guides/" style="color:inherit;text-decoration:none;">Guides</a> / {d.shortName}</p>
    <h1 style="font-size: clamp(28px, 4.5vw, 40px); margin-top: 12px;">{d.title}</h1>

    <div class="copy-widget" style="margin-top: 26px;">
      <span class="big">{d.symbol}</span>
      <span class="meta">
        <span class="name">{d.shortName}</span>
        <span class="code">{d.codepoint}{d.altCode ? `  ·  ${d.altCode}` : ''}</span>
      </span>
      <button class="copy-btn" type="button" data-char={d.symbol}>Copy symbol</button>
    </div>

    <div class="body">
      <Content />
    </div>

    <p style="margin-top: 48px; font-family: var(--font-display);">
      <a href="/symbols/" style="color: var(--accent); text-decoration: none; font-weight: 500;">
        ← Browse all symbols
      </a>
    </p>
  </article>
</Base>
